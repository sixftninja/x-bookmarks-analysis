# X API (OAuth 2.0 confidential client)
# Get these from developer.x.com → your app → Keys and Tokens
X_CLIENT_ID=
X_CLIENT_SECRET=

# LLM provider — choose one: anthropic, openai, google, xai, meta
LLM_PROVIDER=anthropic
# Model name for the chosen provider — pick any model your provider supports
# Examples: claude-sonnet-4-5, gpt-4o, gemini-2.0-flash, grok-3, llama3.1-70b-instruct
LLM_MODEL=

# API key for your chosen provider (only the one you use is required)
ANTHROPIC_API_KEY=      # console.anthropic.com
# OPENAI_API_KEY=       # platform.openai.com
# GOOGLE_API_KEY=       # aistudio.google.com
# XAI_API_KEY=          # console.x.ai
# META_API_KEY=         # llama.com

# Optional: token pricing (USD per million) for cost display in sync output
# If not set, sync will still run but won't show an estimated cost
# LLM_INPUT_PRICE_MTOK=
# LLM_OUTPUT_PRICE_MTOK=

# Sync endpoint protection — generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
SYNC_SECRET=

# Database path
# Local: ./bookmarks.db
# Railway: /app/data/bookmarks.db
DATABASE_URL=./bookmarks.db
